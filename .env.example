# =============================================================
# nail-bot — Environment Variables Template
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values below
# 3. NEVER commit the .env file to git
# =============================================================

# --- Telegram Bot ---
# Get from @BotFather → /newbot
BOT_TOKEN=your_bot_token_here

# --- Admin ---
# Your personal Telegram user ID (get from @userinfobot)
ADMIN_ID=123456789

# --- Subscription Channel ---
# The channel users must subscribe to before using the bot
# Format: -100XXXXXXXXXX  (must start with -100 for supergroups)
CHANNEL_ID=-100XXXXXXXXXX
# Public invite link for the channel
CHANNEL_LINK=https://t.me/+your_invite_link

# --- Notification Channel ---
# Channel where new booking notifications are sent
# Can be the same as CHANNEL_ID
ADMIN_CHANNEL_ID=-100XXXXXXXXXX

# Path to SQLite database
# Docker: /data/nail_bot.db  |  Local: nail_bot.db
DB_PATH=/data/nail_bot.db
